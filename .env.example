# =============================================================================
# OPTIMIXAGE - Variables de Entorno (plantilla)
# Copia este archivo como `.env` y reemplaza los valores marcados con [...]
# =============================================================================

# -----------------------------------------------------------------------------
# Base de datos
# -----------------------------------------------------------------------------
# Opcion A) Supabase (produccion / nube). Pega aqui el "Connection string" de
#           Settings > Database > Connection pooling (Session mode 5432).
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres
#
# Opcion B) PostgreSQL local (docker-compose lo levanta automaticamente)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/optimixagedb
#
# Opcion C) SQLite local (sin dependencias externas, pensado para pruebas rapidas)
DATABASE_URL=sqlite:///./optimixage.db

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
# Genera una clave segura, por ejemplo:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-please-generate-a-real-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Lista separada por comas con los origenes permitidos del frontend.
# Anade aqui la URL publica del frontend cuando despliegues a produccion.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000

# -----------------------------------------------------------------------------
# Bootstrap del primer administrador
# -----------------------------------------------------------------------------
# Solo se aplica si la tabla usuarios esta vacia (primera ejecucion). Permite
# entrar al sistema desde un clon limpio sin tocar la BD a mano.
BOOTSTRAP_ADMIN_EMAIL=admin@optimixage.local
BOOTSTRAP_ADMIN_PASSWORD=Admin1234!
BOOTSTRAP_ADMIN_NOMBRE=Administrador

# -----------------------------------------------------------------------------
# Almacenamiento de archivos subidos
# -----------------------------------------------------------------------------
UPLOADS_DIR=uploads

# -----------------------------------------------------------------------------
# Entorno
# -----------------------------------------------------------------------------
# development | staging | production
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Supabase API (opcional, solo si se consume desde el frontend)
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# docker-compose (postgres local)
# -----------------------------------------------------------------------------
POSTGRES_PASSWORD=postgres
