# =============================================================================
# Frontend (Vite) - Variables de entorno
# Copia este archivo como `.env` (o `.env.local`) y ajusta segun tu entorno.
# Solo las variables con prefijo VITE_ se exponen al codigo cliente.
# =============================================================================

# URL base de la API. En desarrollo Vite la usa como destino del proxy /api.
# En produccion el bundle apunta directamente aqui (asegurate de incluir el
# protocolo y el puerto).
VITE_API_URL=http://localhost:8000
